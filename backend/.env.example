PORT=4000
HOSTNAME=localhost
NODE_ENV=development
SSL=false
SSL_KEY_PATH=""
SSL_CERT_PATH=""

# MongoDB connection string (Atlas or local)
MONGODB_URL='mongodb+srv://<username>:<password>@<cluster>.mongodb.net/datingApp?retryWrites=true&w=majority&appName=<appName>'

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# Default super-admin (seeded on first boot if no admin account exists)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@datingapp.com
ADMIN_PASSWORD=admin123

APP_NAME=Dating App

# --- OTP settings ---
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
# In development the generated OTP is returned in the API response and logged to
# the server console (no SMS gateway needed). Set OTP_DEV_MODE=false in production
# and plug a real SMS provider into ApiAuthService.sendSms().
OTP_DEV_MODE=true

# --- Cloudinary media storage ---
# Folder layout: <ROOT_FOLDER>/<user-slug>/<kind>/<timestamp>_<ASSET_TAG>.<ext>
#   sn/mrinmoy123/profile-images/1784207246060_sangamX.png
#   sn/mrinmoy123/reels/1784207246060_sangamX.mp4
# Required — all photos and videos are stored on Cloudinary, never on disk.
# CLOUDINARY_URL alone is enough; the three separate vars are the same thing spelled out.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=sn
CLOUDINARY_ASSET_TAG=sangamX
# Optional private-CDN domain, e.g. sangamx.cloudinary.com (needs a paid plan)
# CLOUDINARY_SECURE_DIST=
